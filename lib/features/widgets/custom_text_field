import 'package:flutter/material.dart';
import 'package:flutter_screenutil/flutter_screenutil.dart';
import 'package:organization/utils/assets_path.dart';
import '../../utils/app_color.dart';
import '../../utils/app_text_styles.dart';

class CustomTextField extends StatefulWidget {
  const CustomTextField({
    super.key,
    required this.hintText,
    this.prefixIcon,
    this.controller,
    this.suffixIcon,
    this.validator,
    this.onChanged,
    this.onFieldSubmitted,
    this.readOnly = false,
    this.autofillHints,
    this.keyboardType = TextInputType.text,
    this.isPassword = false,
    this.borderColor = const Color(0xFFE4E4E4),
    this.height,
    this.maxLines,
    this.hintTextStyle,
    this.textStyle,
  });

  final String hintText;
  final Widget? prefixIcon;
  final Widget? suffixIcon;
  final TextEditingController? controller;
  final FormFieldValidator<String>? validator;
  final ValueChanged<String>? onChanged;
  final ValueChanged<String>? onFieldSubmitted;
  final bool readOnly;
  final Iterable<String>? autofillHints;
  final TextInputType keyboardType;
  final bool isPassword;
  final Color borderColor;
  final double? height;
  final int? maxLines;
  final TextStyle? hintTextStyle;
  final TextStyle? textStyle;

  @override
  State<CustomTextField> createState() => _CustomTextFieldState();
}

class _CustomTextFieldState extends State<CustomTextField> {
  bool _obscure = true;

  @override
  void initState() {
    super.initState();
    _obscure = widget.isPassword;
  }

  @override
  Widget build(BuildContext context) {
    return SizedBox(
      height: (widget.height ?? 82).h,
      child: TextFormField(
        controller: widget.controller,
        validator: widget.validator,
        keyboardType: widget.keyboardType,
        obscureText: _obscure,
        onChanged: widget.onChanged,
        onFieldSubmitted: widget.onFieldSubmitted,
        readOnly: widget.readOnly,
        autofillHints: widget.autofillHints?.toList(),
        maxLines: widget.maxLines,

        style: widget.textStyle ??
            AppTextStyle.mediumStyle.copyWith(
              fontWeight: FontWeight.w500,
              color: AppColors.blackTextColor,
            ),

        decoration: InputDecoration(
          hintText: widget.hintText,


          hintStyle: widget.hintTextStyle ??
              AppTextStyle.mediumStyle.copyWith(
                color: const Color(0xFFCCCCCC),
                fontSize: 14.sp,
              ),

          filled: true,
          fillColor: Colors.white,
          prefixIconColor: AppColors.blackTextColor,
          isDense: true,
          contentPadding: EdgeInsets.symmetric(
            horizontal: 12.w,
            vertical: 14.h,
          ),

          prefixIcon: widget.prefixIcon != null
              ? Padding(
            padding: EdgeInsets.only(left: 12.w, right: 8.w),
            child: widget.prefixIcon,
          )
              : null,
          prefixIconConstraints: const BoxConstraints(
            minWidth: 0,
            minHeight: 0,
          ),

          suffixIcon: widget.isPassword
              ? GestureDetector(
            onTap: () {
              setState(() {
                _obscure = !_obscure;
              });
            },
            child: Padding(
              padding: EdgeInsets.symmetric(horizontal: 12.w),
              child: Image.asset(
                _obscure ? AssetsPath.eyeIcon : AssetsPath.eyeIcon,
                width: 20.w,
                height: 20.h,
                color: AppColors.blackTextColor,
              ),
            ),
          )
              : widget.suffixIcon,

          // ✅ borders
          enabledBorder: OutlineInputBorder(
            borderRadius: BorderRadius.circular(12.r),
            borderSide: BorderSide(
              color: widget.borderColor,
              width: 1.0,
            ),
          ),
          focusedBorder: OutlineInputBorder(
            borderRadius: BorderRadius.circular(12.r),
            borderSide: BorderSide(
              color: widget.borderColor,
              width: 1.0,
            ),
          ),
          // error border – পুরো outline লাল
          errorBorder: OutlineInputBorder(
            borderRadius: BorderRadius.circular(12.r),
            borderSide: BorderSide(color: Colors.red, width: 1),
          ),



        ),
      ),
    );
  }
}
